# --- Mac dashboard (Vite) ---
# Point Vite's /api proxy at your Kaggle dev tunnel (Node on port 4000).
VITE_GPU_API_TARGET=https://YOUR-TUNNEL-4000.use.devtunnels.ms
# Set to 0 to force browser speechSynthesis only.
VITE_USE_GPU_TTS=1
# Lip mode on Mac: canvas | musetalk | wav2lip (VITE_AVATAR_MODE overrides legacy flag below)
VITE_AVATAR_MODE=canvas
# Legacy: 0=canvas, 1=wav2lip, 2=musetalk
VITE_USE_TALKING_AVATAR=0
# DEVTUNNEL_ACCESS_TOKEN=your-token-here

# --- Kaggle Python TTS (modelServer.py) ---
# HOST=0.0.0.0   # default — do not set to a single “real IP” unless you know why
# PORT=5000

# --- Kaggle backend (after unzip) ---
# cd server && bash setup-kaggle.sh && source .venv/bin/activate && python modelServer.py
# MuseTalk (optional): bash setup-musetalk.sh then USE_TALKING_AVATAR=2 python modelServer.py
# Wav2Lip (optional): bash setup-wav2lip.sh then USE_TALKING_AVATAR=1 python modelServer.py
# (Python 3.12 → Edge TTS; Python 3.10/11 → Coqui GPU)
# cd .. && npm install && npm run dev:gpu-server
# Ports: 4000 Public → paste URL into VITE_GPU_API_TARGET above.
